{
  "synesis-guardrail": {
    "PreToolUse": [
      {
        "matcher": "write_to_file|replace_file_content|multi_replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "C:\\path\\to\\synesis\\cli\\build\\install\\synesis\\bin\\synesis.bat hook antigravity --profile C:\\path\\to\\project\\.synesis\\local\\profile",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
