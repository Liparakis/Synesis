{
  "synesis-guardrail": {
    "PreToolUse": [
      {
        "matcher": "write_to_file|replace_file_content|multi_replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File C:\\path\\to\\project\\.synesis\\local\\run-antigravity-hook.ps1",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
